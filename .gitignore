/target

# Local Arch packaging artifacts
/pkg/
/petiglyph-*.tar.gz
/petiglyph-*.pkg.tar.zst
/petiglyph-debug-*.pkg.tar.zst

# Isolated makepkg workspace used by scripts/aur.sh
/.makepkg/

# Generated makepkg extraction/output under src/
/src/petiglyph/
/src/petiglyph-*.tar.gz

/build/
/icons/

# Local throwaway petiglyph projects (kept out of git by naming convention)
/test[0-9]*/
/test-*/
!/test-assets/
/test_parse*
/test_ws*
/pp-*/

# npm/PyPI local packaging artifacts
/petiglyph-*.tgz
/npm/petiglyph/*.tgz
/*.whl

# Staged native npm release binaries (keep placeholders)
/npm/petiglyph-*/bin/*
!/npm/petiglyph-*/bin/.gitkeep

# Common local caches
/node_modules/
/.venv/
/venv/
/.pytest_cache/
/.mypy_cache/
/.ruff_cache/
/**/__pycache__/
